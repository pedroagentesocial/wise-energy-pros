---
import { getDictionary, isLocale, locales, localizedPath } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import ValidatedLeadForm from '../../components/ValidatedLeadForm';

export const getStaticPaths = () => {
	return locales.map((lang) => ({
		params: { lang },
	}));
};

const lang = Astro.params.lang ?? 'en';
if (!isLocale(lang)) {
	throw new Error('Unsupported locale');
}
const t = getDictionary(lang);
const privacyUrl = localizedPath(lang, '/privacy-policy');
const termsUrl = localizedPath(lang, '/terms-and-conditions');
---

<Layout title={t.meta.contact.title} description={t.meta.contact.description} lang={lang}>
	<section class="bg-slate-950 py-20">
		<div class="container mx-auto px-6 opacity-0 translate-y-4" data-reveal data-stagger-parent>
			<h1 class="text-4xl font-extrabold text-slate-50 md:text-5xl">{t.contact.heading}</h1>
			<p class="mt-4 max-w-3xl text-slate-400">{t.contact.intro}</p>
			<div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2">
				<div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:border-cyan-400/50 md:p-6" data-stagger-item>
					<h2 class="mb-4 text-xl font-bold text-slate-50">{t.contact.mapTitle}</h2>
					<div class="overflow-hidden rounded-xl border border-slate-800">
						<iframe
							title={t.contact.mapTitle}
							src="https://www.google.com/maps?q=United+States&output=embed"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							class="h-72 w-full md:h-[30rem]"
						></iframe>
					</div>
				</div>
				<div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:border-cyan-400/50" data-stagger-item>
					<ValidatedLeadForm
						client:load
						strings={t.forms}
						submitLabel={t.contact.form.submit}
						showService={true}
						showMessage={true}
						privacyHref={privacyUrl}
						termsHref={termsUrl}
					/>
				</div>
			</div>
		</div>
	</section>
</Layout>
