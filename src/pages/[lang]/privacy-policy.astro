---
import Layout from '../../layouts/Layout.astro';
import { getDictionary, isLocale, locales } from '../../i18n';

export const getStaticPaths = () => {
	return locales.map((lang) => ({
		params: { lang },
	}));
};

const lang = Astro.params.lang ?? 'en';
if (!isLocale(lang)) {
	throw new Error('Unsupported locale');
}
const t = getDictionary(lang);

const copy = {
	en: {
		title: 'Privacy Policy',
		effective: 'Effective date: March 20, 2026',
		intro: 'Wise Energy Pros values your privacy. This Privacy Policy explains what information we collect, how we use it, how we protect it, and what choices you have when using our website and contacting us for services.',
	},
	es: {
		title: 'Política de Privacidad',
		effective: 'Fecha de vigencia: 20 de marzo de 2026',
		intro: 'Wise Energy Pros valora su privacidad. Esta Política de Privacidad explica qué información recopilamos, cómo la usamos, cómo la protegemos y qué opciones tiene al usar nuestro sitio web y contactarnos para servicios.',
	},
}[lang];
---

<Layout title={`${copy.title} | Wise Energy Pros`} description={t.meta.contact.description} lang={lang}>
	<section class="bg-slate-950 py-20">
		<div class="container mx-auto max-w-4xl px-6">
			<h1 class="text-4xl font-extrabold text-slate-50 md:text-5xl">{copy.title}</h1>
			<p class="mt-4 text-slate-400">{copy.effective}</p>
			<p class="mt-6 text-slate-400">{copy.intro}</p>

			<h2 class="mt-10 text-2xl font-bold text-slate-50">{lang === 'en' ? '1. Information We Collect' : '1. Información que recopilamos'}</h2>
			<ul class="mt-3 list-disc space-y-2 pl-6 text-slate-400">
				<li>{lang === 'en' ? 'Contact details such as name, email, and phone number.' : 'Datos de contacto como nombre, correo electrónico y teléfono.'}</li>
				<li>{lang === 'en' ? 'Service request details such as project type, message, and property context.' : 'Detalles de solicitud de servicio como tipo de proyecto, mensaje y contexto de la propiedad.'}</li>
				<li>{lang === 'en' ? 'Communication preferences and consent selections.' : 'Preferencias de comunicación y selecciones de consentimiento.'}</li>
			</ul>

			<h2 class="mt-10 text-2xl font-bold text-slate-50">{lang === 'en' ? '2. How We Use Data' : '2. Cómo usamos los datos'}</h2>
			<ul class="mt-3 list-disc space-y-2 pl-6 text-slate-400">
				<li>{lang === 'en' ? 'To respond to inquiries and provide project estimates.' : 'Para responder consultas y proporcionar estimaciones de proyecto.'}</li>
				<li>{lang === 'en' ? 'To coordinate scheduling, follow-up, and support communication.' : 'Para coordinar agenda, seguimiento y comunicación de soporte.'}</li>
				<li>{lang === 'en' ? 'To improve service quality and website experience.' : 'Para mejorar la calidad del servicio y la experiencia del sitio web.'}</li>
			</ul>

			<h2 class="mt-10 text-2xl font-bold text-slate-50">{lang === 'en' ? '3. Data Sharing and Security' : '3. Compartición y seguridad de datos'}</h2>
			<p class="mt-3 text-slate-400">
				{lang === 'en'
					? 'We do not sell personal data. We may share limited information with trusted providers strictly required to operate hosting, communications, and service workflows. We apply reasonable technical and administrative safeguards to protect stored information.'
					: 'No vendemos datos personales. Podemos compartir información limitada con proveedores de confianza únicamente cuando sea necesario para operar hosting, comunicaciones y flujos de servicio. Aplicamos medidas técnicas y administrativas razonables para proteger la información almacenada.'}
			</p>

			<h2 class="mt-10 text-2xl font-bold text-slate-50">{lang === 'en' ? '4. Your Rights' : '4. Sus derechos'}</h2>
			<p class="mt-3 text-slate-400">
				{lang === 'en'
					? 'You may request access, correction, or deletion of your personal information where legally applicable. To submit a request, contact us at'
					: 'Puede solicitar acceso, corrección o eliminación de su información personal cuando sea legalmente aplicable. Para enviar una solicitud, contáctenos en'}
				{' '}
				<a href="mailto:intake@wiseenergypros.com" class="font-medium text-cyan-300 transition-colors duration-300 hover:text-cyan-200">intake@wiseenergypros.com</a>.
			</p>

			<h2 class="mt-10 text-2xl font-bold text-slate-50">{lang === 'en' ? '5. Updates' : '5. Actualizaciones'}</h2>
			<p class="mt-3 text-slate-400">
				{lang === 'en'
					? 'We may update this policy to reflect legal or operational changes. Updates are posted on this page.'
					: 'Podemos actualizar esta política para reflejar cambios legales u operativos. Las actualizaciones se publican en esta misma página.'}
			</p>
		</div>
	</section>
</Layout>
