---
import HeroVideoSlider from '../../components/HeroVideoSlider';
import ProjectGallery from '../../components/ProjectGallery';
import ServicesGrid from '../../components/ServicesGrid';
import TestimonialsMarquee from '../../components/TestimonialsMarquee';
import ValidatedLeadForm from '../../components/ValidatedLeadForm';
import WhyChooseGrid from '../../components/WhyChooseGrid';
import { getDictionary, isLocale, locales } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = () => {
	return locales.map((lang) => ({
		params: { lang },
	}));
};

const lang = Astro.params.lang ?? 'en';
if (!isLocale(lang)) {
	throw new Error('Unsupported locale');
}
const t = getDictionary(lang);
const serviceItems = t.home.servicesSection.items.map((item) => ({
	...item,
	icon: item.icon as 'installation' | 'maintenance' | 'panel' | 'renovation' | 'ev',
}));
const galleryProjects = t.home.gallery.projects;
const whyChooseItems = t.home.whyChoose.items.map((item) => ({
	...item,
	icon: item.icon as 'licensed' | 'fast' | 'technicians' | 'pricing' | 'materials' | 'satisfaction',
}));
const contactPhoneDial = '+18005550145';
---

<Layout title={t.meta.home.title} description={t.meta.home.description} lang={lang}>
	<HeroVideoSlider
		client:load
		lang={lang}
		slides={t.home.heroSlider.slides}
		ariaLabel={t.home.heroSlider.ariaLabel}
		previousLabel={t.home.heroSlider.previous}
		nextLabel={t.home.heroSlider.next}
		goToLabel={t.home.heroSlider.goTo}
	/>

	<ServicesGrid client:load heading={t.home.servicesSection.heading} items={serviceItems} />

	<WhyChooseGrid client:load heading={t.home.whyChoose.heading} intro={t.home.whyChoose.intro} items={whyChooseItems} />

	<ProjectGallery client:load heading={t.home.gallery.heading} projects={galleryProjects} />

	<TestimonialsMarquee
		client:load
		heading={t.home.testimonials.heading}
		sourceLabel={t.home.testimonials.sourceLabel}
		location={t.home.testimonials.location}
		items={t.home.testimonials.items}
	/>

	<section class="bg-slate-950 py-20">
		<div class="container mx-auto px-6 opacity-0 translate-y-4" data-reveal>
			<div class="mx-auto max-w-5xl rounded-3xl border border-slate-800 bg-slate-900/50 p-8 text-center backdrop-blur-md transition-all duration-300 hover:border-cyan-400/50 md:p-12">
				<h2 class="text-3xl font-bold text-slate-50 md:text-5xl">{t.home.finalCta.heading}</h2>
				<p class="mx-auto mt-4 max-w-3xl text-slate-400">{t.home.finalCta.subheading}</p>
				<div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href={`/${lang}/contact`} class="inline-flex items-center justify-center rounded-full bg-blue-600 px-8 py-3.5 text-base font-bold text-slate-50 transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-500">
						{t.home.finalCta.primary}
					</a>
					<a href={`tel:${contactPhoneDial}`} class="inline-flex items-center justify-center rounded-full border border-cyan-400/70 bg-cyan-400/10 px-8 py-3.5 text-base font-bold text-cyan-400 transition-all duration-300 hover:-translate-y-0.5 hover:bg-cyan-400/20">
						{t.home.finalCta.secondary}
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-950 py-20">
		<div class="container mx-auto px-6 opacity-0 translate-y-4" data-reveal data-stagger-parent>
			<h2 class="text-center text-3xl font-bold text-slate-50 md:text-4xl">{t.home.contactSection.heading}</h2>
			<p class="mx-auto mt-4 max-w-2xl text-center text-slate-400">{t.home.contactSection.intro}</p>
			<div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-5">
				<div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:border-cyan-400/50 lg:col-span-3" data-stagger-item>
					<h3 class="mb-4 text-xl font-bold text-slate-50">{t.home.contactSection.mapTitle}</h3>
					<div class="overflow-hidden rounded-xl border border-slate-800">
						<iframe
							title={t.home.contactSection.mapTitle}
							src="https://www.google.com/maps?q=United+States&output=embed"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							class="h-72 w-full md:h-[32rem]"
						></iframe>
					</div>
				</div>
				<div class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:border-cyan-400/50 lg:col-span-2" data-stagger-item>
					<ValidatedLeadForm
						client:load
						strings={t.forms}
						submitLabel={t.home.contactSection.form.submit}
						showService={true}
						showMessage={true}
						privacyHref={`/${lang}/privacy-policy`}
						termsHref={`/${lang}/terms-and-conditions`}
					/>
				</div>
			</div>
		</div>
	</section>
</Layout>
