---
import { getDictionary, isLocale, locales } from '../../i18n';
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = () => {
	return locales.map((lang) => ({
		params: { lang },
	}));
};

const lang = Astro.params.lang ?? 'en';
if (!isLocale(lang)) {
	throw new Error('Unsupported locale');
}
const t = getDictionary(lang);
---

<Layout title={t.meta.services.title} description={t.meta.services.description} lang={lang}>
	<section class="bg-slate-950 py-20">
		<div class="container mx-auto px-6 opacity-0 translate-y-4" data-reveal data-stagger-parent>
			<h1 class="text-4xl font-extrabold text-slate-50 md:text-5xl">{t.services.heading}</h1>
			<p class="mt-4 max-w-3xl text-slate-400">{t.services.intro}</p>
			<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
				<article class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-400/60" data-stagger-item>
					<h2 class="text-2xl font-bold text-slate-50">{t.services.cards.panel.title}</h2>
					<p class="mt-3 text-slate-400">{t.services.cards.panel.description}</p>
				</article>
				<article class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-400/60" data-stagger-item>
					<h2 class="text-2xl font-bold text-slate-50">{t.services.cards.nec.title}</h2>
					<p class="mt-3 text-slate-400">{t.services.cards.nec.description}</p>
				</article>
				<article class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-400/60" data-stagger-item>
					<h2 class="text-2xl font-bold text-slate-50">{t.services.cards.maintenance.title}</h2>
					<p class="mt-3 text-slate-400">{t.services.cards.maintenance.description}</p>
				</article>
				<article class="rounded-2xl border border-slate-800 bg-slate-900/50 p-6 backdrop-blur-md opacity-0 translate-y-3 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-400/60" data-stagger-item>
					<h2 class="text-2xl font-bold text-slate-50">{t.services.cards.integration.title}</h2>
					<p class="mt-3 text-slate-400">{t.services.cards.integration.description}</p>
				</article>
			</div>
		</div>
	</section>
</Layout>
