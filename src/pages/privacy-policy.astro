---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy | Wise Energy Pros" description="Privacy Policy for Wise Energy Pros website inquiries and service requests." lang="en">
	<section class="bg-slate-950 py-20">
		<div class="container mx-auto max-w-4xl px-6">
			<h1 class="text-4xl font-extrabold text-slate-50 md:text-5xl">Privacy Policy</h1>
			<p class="mt-4 text-slate-400">
				We collect contact information submitted through our forms to respond to service inquiries, provide estimates, and improve customer support. We do not sell personal data.
			</p>
			<p class="mt-4 text-slate-400">
				By using this website, you agree that submitted information may be used by Wise Energy Pros for project communication and service-related follow-up.
			</p>
		</div>
	</section>
</Layout>
