---
const baseUrl = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta http-equiv="refresh" content={`0;url=${baseUrl}en/`} />
		<title>Wise Energy Pros</title>
	</head>
	<body class="bg-slate-950">
		<script is:inline define:vars={{ baseUrl }}>
			const localeStorageKey = 'wise-energy-pros:locale';
			const locale = localStorage.getItem(localeStorageKey) || 'en';
			const base = baseUrl;
			const target = locale === 'es' ? `${base}es/` : `${base}en/`;
			window.location.replace(target);
		</script>
	</body>
</html>
