---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms and Conditions | Wise Energy Pros" description="Terms and Conditions for Wise Energy Pros website and service requests." lang="en">
	<section class="bg-slate-950 py-20">
		<div class="container mx-auto max-w-4xl px-6">
			<h1 class="text-4xl font-extrabold text-slate-50 md:text-5xl">Terms and Conditions</h1>
			<p class="mt-4 text-slate-400">
				Information on this website is provided for general service guidance. Final pricing, scope, and scheduling are confirmed in written project proposals.
			</p>
			<p class="mt-4 text-slate-400">
				Submitting a form does not create a binding contract. All projects are subject to site review, code requirements, and formal acceptance of service terms.
			</p>
		</div>
	</section>
</Layout>
