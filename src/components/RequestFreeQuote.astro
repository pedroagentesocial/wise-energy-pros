---
interface Props {
	lead: {
		heading: string;
		subheading: string;
		quote: string;
		call: string;
		whatsapp: string;
	};
	contactLabels: {
		phone: string;
		email: string;
		location: string;
	};
	social: {
		facebook: string;
		instagram: string;
		linkedin: string;
	};
	location: string;
	localizedContactUrl: string;
	contactPhoneDisplay: string;
	contactPhoneDial: string;
	whatsappUrl: string;
	email: string;
}

const {
	lead,
	contactLabels,
	social,
	location,
	localizedContactUrl,
	contactPhoneDisplay,
	contactPhoneDial,
	whatsappUrl,
	email,
} = Astro.props;
---

<div class="relative grid grid-cols-1 gap-6 overflow-hidden rounded-3xl border border-slate-800/90 bg-gradient-to-br from-slate-900/55 via-slate-900/45 to-slate-950/70 p-6 backdrop-blur-md transition-all duration-500 hover:border-cyan-400/40 lg:grid-cols-5 lg:items-stretch lg:p-8">
	<div class="pointer-events-none absolute -left-16 -top-16 h-44 w-44 rounded-full bg-blue-500/15 blur-3xl"></div>
	<div class="pointer-events-none absolute -bottom-20 right-0 h-52 w-52 rounded-full bg-cyan-400/12 blur-3xl"></div>
	<div class="relative lg:col-span-3">
		<p class="inline-flex items-center rounded-full border border-slate-700/80 bg-slate-950/60 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-cyan-300">
			Request a Free Quote
		</p>
		<h2 class="mt-4 text-2xl font-extrabold leading-tight text-slate-50 md:text-3xl">{lead.heading}</h2>
		<p class="mt-3 max-w-2xl text-slate-300">{lead.subheading}</p>
		<div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
			<a href={localizedContactUrl} class="inline-flex items-center justify-center rounded-full bg-blue-600 px-6 py-3 text-sm font-extrabold text-slate-50 shadow-[0_0_22px_rgba(37,99,235,0.45)] ring-1 ring-blue-400/40 transition-all duration-300 hover:-translate-y-0.5 hover:scale-[1.01] hover:bg-blue-500">
				{lead.quote}
			</a>
			<a href={`tel:${contactPhoneDial}`} class="inline-flex items-center justify-center rounded-full border border-slate-700 bg-slate-950/70 px-6 py-3 text-sm font-semibold text-slate-100 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-400/70 hover:text-cyan-300">
				{lead.call}
			</a>
			<a href={whatsappUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-cyan-400/60 bg-cyan-400/10 px-6 py-3 text-sm font-bold text-cyan-300 transition-all duration-300 hover:-translate-y-0.5 hover:bg-cyan-400/20">
				{lead.whatsapp}
			</a>
		</div>
	</div>
	<div class="relative rounded-2xl border border-slate-800 bg-slate-950/82 p-5 shadow-[0_14px_34px_rgba(2,6,23,0.3)] lg:col-span-2">
		<h3 class="text-sm font-bold uppercase tracking-[0.16em] text-slate-300">Contact Info</h3>
		<ul class="mt-3 space-y-2.5 text-sm text-slate-300">
			<li>{contactLabels.phone}: <a href={`tel:${contactPhoneDial}`} class="font-medium transition-colors duration-300 hover:text-cyan-300">{contactPhoneDisplay}</a></li>
			<li>{contactLabels.email}: <a href={`mailto:${email}`} class="font-medium transition-colors duration-300 hover:text-cyan-300">{email}</a></li>
			<li>{contactLabels.location}: <span class="font-medium">{location}</span></li>
		</ul>
		<div class="mt-5 flex items-center gap-3">
			<a href="https://facebook.com" target="_blank" rel="noreferrer" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-700 text-slate-300 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:border-cyan-400/70 hover:text-cyan-400" aria-label={social.facebook}>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4">
					<path d="M13 21v-8h3l.5-3H13V8.5c0-.9.3-1.5 1.5-1.5H17V4h-2.6C11.5 4 10 5.7 10 8.4V10H7v3h3v8h3Z" />
				</svg>
			</a>
			<a href="https://instagram.com" target="_blank" rel="noreferrer" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-700 text-slate-300 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:border-cyan-400/70 hover:text-cyan-400" aria-label={social.instagram}>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4">
					<rect x="3.5" y="3.5" width="17" height="17" rx="4" />
					<circle cx="12" cy="12" r="3.5" />
					<circle cx="17.5" cy="6.5" r="0.6" />
				</svg>
			</a>
			<a href="https://linkedin.com" target="_blank" rel="noreferrer" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-700 text-slate-300 transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:border-cyan-400/70 hover:text-cyan-400" aria-label={social.linkedin}>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4">
					<path d="M7 10v7M7 7.5v.1M11 17v-4.2c0-1.7 1.1-2.8 2.5-2.8S16 11 16 12.7V17M4 17h16" />
				</svg>
			</a>
		</div>
	</div>
</div>
